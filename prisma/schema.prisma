generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Post {
  id       Int       @id @default(autoincrement())
  question  String    @db.VarChar(255)
  answer     String @db.VarChar(255)
  country  String    @db.Text

  @@map("posts")
}

